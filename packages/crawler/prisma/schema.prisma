generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String         @id
  title              String
  brand              String?
  originalPrice      Int?
  imageUrl           String?
  stockStatus        String?
  bestBenefit        String?
  category           String?        // /api/item 응답의 item_category_name (내부 분류, 일관성 낮음)
  subCategory        String?        // /api/item 응답의 brand_item_category_name
  thirdCategory      String?        // @deprecated → thirdCategories
  menuCategory       String?        // @deprecated → menuCategories
  menuSubCategory    String?        // @deprecated → menuSubCategories
  // N:M 매핑: 한 상품이 univstore 메뉴의 여러 분류에 동시 노출될 수 있음
  menuCategories     String[]       @default([])
  menuSubCategories  String[]       @default([])
  thirdCategories    String[]       @default([])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  priceHistory       PriceHistory[]
  priceAlerts        PriceAlert[]
  dailyPick          DailyPick?

  @@index([menuCategory, menuSubCategory])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  String
  price      Int
  timestamp  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId, timestamp])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  time      DateTime @default(now())
  type      String
  service   String
  message   String
}

model DataIssue {
  id        Int      @id @default(autoincrement())
  productId String
  type      String   // MISSING_IMAGE, MISSING_TITLE, ERROR
  message   String
  details   String?
  timestamp DateTime @default(now())

  @@unique([productId, type])
  @@index([productId])
  @@index([type])
}

model BenefitRule {
  id        Int      @id @default(autoincrement())
  pattern   String   @unique // Regex or keyword pattern
  rate      Float    // Discount rate (e.g., 0.03)
  maxLimit  Int      // Max discount amount
  label     String
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Raffle {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  entries   Int      @default(0)
  endsAt    DateTime
  winners   Int      @default(1)
  prob      String?  // 계산된 확률
  imageUrl  String?
  status    String   @default("Ongoing") // Ongoing, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlashSale {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  discount  String?
  stock     Int?
  startTime DateTime
  endTime   DateTime
  status    String   @default("Upcoming") // Ongoing, Upcoming, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceAlert {
  id              Int      @id @default(autoincrement())
  productId       String
  targetPrice     Int
  isActive        Boolean  @default(true)
  subscriberToken String?
  lastNotifiedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([subscriberToken])
}


model CrawlerStatus {
  id            String   @id @default("singleton")
  totalItems    Int      @default(0)
  currentIndex  Int      @default(0)
  lastStatus    String   @default("IDLE") // IDLE, RUNNING, BLOCKED, COMPLETED
  lastHeartbeat DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DailyPick {
  id        Int      @id @default(autoincrement())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  chatId    String
  createdAt DateTime @default(now())
}

