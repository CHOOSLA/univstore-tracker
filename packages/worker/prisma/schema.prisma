generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String         @id
  title         String
  brand         String?
  originalPrice Int?
  imageUrl      String?
  stockStatus   String?
  bestBenefit   String?
  category      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  priceHistory  PriceHistory[]
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  String
  price      Int
  timestamp  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId, timestamp])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  time      DateTime @default(now())
  type      String
  service   String
  message   String
}

model DataIssue {
  id        Int      @id @default(autoincrement())
  productId String
  type      String   // MISSING_IMAGE, MISSING_TITLE, ERROR
  message   String
  details   String?
  timestamp DateTime @default(now())

  @@index([productId])
  @@index([type])
}

model Raffle {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  entries   Int      @default(0)
  endsAt    DateTime
  winners   Int      @default(1)
  prob      String?  // 계산된 확률
  imageUrl  String?
  status    String   @default("Ongoing") // Ongoing, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlashSale {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  discount  String?
  stock     Int?
  startTime DateTime
  endTime   DateTime
  status    String   @default("Upcoming") // Ongoing, Upcoming, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
