generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String         @id
  title              String
  brand              String?
  originalPrice      Int?
  imageUrl           String?
  stockStatus        String?
  bestBenefit        String?
  currentPrice       Int?
  medianPrice30d     Int?
  lowestPrice        Int?
  highestPrice       Int?
  priceScore         Int?           // 0~100. 100=역대최저, 0=역대최고. (highest-current)*100/(highest-lowest)
  category           String?        // /api/item 응답의 item_category_name (내부 분류, 일관성 낮음)
  subCategory        String?        // /api/item 응답의 brand_item_category_name
  thirdCategory      String?        // @deprecated → thirdCategories
  menuCategory       String?        // @deprecated → menuCategories
  menuSubCategory    String?        // @deprecated → menuSubCategories
  // N:M 매핑: 한 상품이 univstore 메뉴의 여러 분류에 동시 노출될 수 있음
  menuCategories     String[]       @default([])
  menuSubCategories  String[]       @default([])
  thirdCategories    String[]       @default([])
  mnoOption          MnoOption?     // 통신사 상품일 때만 row 존재 (1:1)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  priceHistory       PriceHistory[]
  priceAlerts        PriceAlert[]
  dailyPick          DailyPick?
  watchlistItems     WatchlistItem[]

  @@index([menuCategory, menuSubCategory])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  String
  price      Int
  timestamp  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId, timestamp])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  time      DateTime @default(now())
  type      String
  service   String
  message   String
}

model DataIssue {
  id        Int      @id @default(autoincrement())
  productId String
  type      String   // MISSING_IMAGE, MISSING_TITLE, ERROR
  message   String
  details   String?
  timestamp DateTime @default(now())

  @@unique([productId, type])
  @@index([productId])
  @@index([type])
}

model BenefitRule {
  id        Int      @id @default(autoincrement())
  pattern   String   @unique // Regex or keyword pattern
  rate      Float    // Discount rate (e.g., 0.03)
  maxLimit  Int      // Max discount amount
  label     String
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Raffle {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  entries   Int      @default(0)
  endsAt    DateTime
  winners   Int      @default(1)
  prob      String?  // 계산된 확률
  imageUrl  String?
  status    String   @default("Ongoing") // Ongoing, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlashSale {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  discount  String?
  stock     Int?
  startTime DateTime
  endTime   DateTime
  status    String   @default("Upcoming") // Ongoing, Upcoming, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceAlert {
  id              Int      @id @default(autoincrement())
  productId       String
  targetPrice     Int
  isActive        Boolean  @default(true)
  subscriberToken String?  // @deprecated 익명 토큰 (계정 도입 전 호환용). 신규는 userId 사용.
  userId          String?
  lastNotifiedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  product         Product  @relation(fields: [productId], references: [id])
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([subscriberToken])
  @@index([userId])
}


model CrawlerStatus {
  id            String   @id @default("singleton")
  totalItems    Int      @default(0)
  currentIndex  Int      @default(0)
  lastStatus    String   @default("IDLE") // IDLE, RUNNING, BLOCKED, COMPLETED
  lastHeartbeat DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DailyPick {
  id        Int      @id @default(autoincrement())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}

model TelegramSubscriber {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  chatId    String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ===== 계정 (Auth.js Prisma Adapter 표준 스키마) =====
model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  watchlistItems      WatchlistItem[]
  priceAlerts         PriceAlert[]
  telegramSubscribers TelegramSubscriber[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===== 관심상품 (Watchlist) =====
model WatchlistItem {
  id        Int      @id @default(autoincrement())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

/// 통신사(mno) 상품의 옵션 메타데이터. Product 1건당 1행 (통신사 상품일 때만).
/// phonePlans는 sub-entity가 단순(평면 객체 배열)이고 함께 조회되는 패턴이라 JSON으로 묶음.
model MnoOption {
  productId          String   @id
  product            Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  deviceColors       String[] @default([]) // option2Text — ["제트블랙","블루쉐도우","코랄레드"]
  deviceCapacities   String[] @default([]) // option1Text — ["256GB"]
  registrationTypes  String[] @default([]) // ["DEVICE_CHANGE","NUMBER_CHANGE","NEW"]
  baseColor          String?  // optionPickers.option2_text — price2 기준 옵션 색상
  baseCapacity       String?  // optionPickers.option1_text — price2 기준 용량
  phonePlans         Json     // [{id,name,monthPrice,publicXXXAmount,additionalXXXAmount,isDefault}, ...]
  updatedAt          DateTime @updatedAt
}

