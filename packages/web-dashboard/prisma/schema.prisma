generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id              String         @id
  title           String
  brand           String?
  originalPrice   Int?
  imageUrl        String?
  stockStatus     String?
  bestBenefit     String?
  category        String?        // /api/item 응답의 item_category_name (내부 분류, 일관성 낮음)
  subCategory     String?        // /api/item 응답의 brand_item_category_name
  thirdCategory   String?
  menuCategory    String?        // univstore 공식 메뉴 1단계 (디지털/컴퓨터/가전/...)
  menuSubCategory String?        // univstore 공식 메뉴 2단계 (태블릿PC/음향기기/...)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  priceHistory    PriceHistory[]
  priceAlerts     PriceAlert[]
  dailyPick       DailyPick?

  @@index([menuCategory, menuSubCategory])
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  productId  String
  price      Int
  timestamp  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id])

  @@index([productId, timestamp])
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  time      DateTime @default(now())
  type      String
  service   String
  message   String
}

model DataIssue {
  id        Int      @id @default(autoincrement())
  productId String
  type      String   // MISSING_IMAGE, MISSING_TITLE, ERROR
  message   String
  details   String?
  timestamp DateTime @default(now())

  @@unique([productId, type])
  @@index([productId])
  @@index([type])
}

model BenefitRule {
  id        Int      @id @default(autoincrement())
  pattern   String   @unique // Regex or keyword pattern
  rate      Float    // Discount rate (e.g., 0.03)
  maxLimit  Int      // Max discount amount
  label     String
  isActive  Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Raffle {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  entries   Int      @default(0)
  endsAt    DateTime
  winners   Int      @default(1)
  prob      String?  // 계산된 확률
  imageUrl  String?
  status    String   @default("Ongoing") // Ongoing, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlashSale {
  id        String   @id @default(uuid())
  title     String
  brand     String?
  discount  String?
  stock     Int?
  startTime DateTime
  endTime   DateTime
  status    String   @default("Upcoming") // Ongoing, Upcoming, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PriceAlert {
  id            Int      @id @default(autoincrement())
  productId     String
  targetPrice   Int
  isActive      Boolean  @default(true)
  lastNotifiedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  product       Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model CrawlerStatus {
  id            String   @id @default("singleton")
  totalItems    Int      @default(0)
  currentIndex  Int      @default(0)
  lastStatus    String   @default("IDLE") // IDLE, RUNNING, BLOCKED, COMPLETED
  lastHeartbeat DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model DailyPick {
  id        Int      @id @default(autoincrement())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
}
