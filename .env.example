# --- 공통 설정 ---
# 에브리타임 계정 정보
EVERYTIME_ID=your_id_here
EVERYTIME_PW=your_password_here

# --- 데이터베이스 및 인프라 설정 ---
# Prisma 데이터베이스 연결 URL (PostgreSQL)
DATABASE_URL="postgresql://univuser:univpassword@localhost:5432/univstore?schema=public"

# Redis 연결 URL (메시지 큐용)
REDIS_URL="redis://localhost:6379"

# --- 알림 설정 (선택 사항) ---
# Telegram Bot 설정 (설정하지 않아도 수집은 정상 진행됩니다)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- 수집 설정 ---
# 수집 대상 상품 ID (동적 수집 미사용 시 참고용)
TARGET_ITEM_IDS=138746,138929

# DirectApi 모드 - 페이지 로드를 건너뛰고 /api/item/{id}를 직접 호출하여 수집 속도 향상.
# 차단 위험이 있을 수 있으므로 처음에는 작은 샘플로 검증한 후 활성화 권장. (true|false)
USE_DIRECT_API=false

# 정식 Chrome 실행 경로 (자동 감지 실패 시 수동 지정)
# CHROME_PATH=/usr/bin/google-chrome

# --- 대시보드 설정 ---
# 공개 URL (OG 메타데이터 및 절대 경로 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
