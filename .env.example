# --- 에브리유니브 계정 ---
EVERYTIME_ID=your_id_here
EVERYTIME_PW=your_password_here

# 수집 대상 상품 ID (동적 수집 미사용 시 참고용)
TARGET_ITEM_IDS=138746,138929

# --- PostgreSQL ---
POSTGRES_USER=univuser
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=univstore

# Prisma 로컬 개발용 (Docker는 docker-compose.yml에서 서비스명으로 자동 구성)
DATABASE_URL="postgresql://univuser:your_db_password_here@localhost:5432/univstore?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Telegram 알림 (선택) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- 수집 설정 ---
# 페이지 로드를 건너뛰고 /api/item/{id} 직접 호출. 처음엔 false로 검증 권장.
USE_DIRECT_API=false

# 정식 Chrome 실행 경로 (자동 감지 실패 시 수동 지정)
# CHROME_PATH=/usr/bin/google-chrome

# --- 대시보드 인프라 ---
VIRTUAL_HOST=your-domain.com
LETSENCRYPT_EMAIL=your_email_here
NEXT_PUBLIC_SITE_URL=https://your-domain.com
